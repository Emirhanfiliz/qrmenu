generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RestaurantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum SubscriptionType {
  TRIAL
  ANNUAL
}

model Restaurant {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  email           String           @unique
  passwordHash    String
  logoUrl         String?
  theme           String           @default("beach")
  tagline         String?
  coverUrl        String?
  address         String?
  phone           String?
  workingHours    String?
  wifiInfo        String?
  showWelcome     Boolean          @default(false)
  instagramUrl    String?
  tiktokUrl       String?
  googleMapsUrl   String?
  googlePlaceId   String?
  status                   RestaurantStatus @default(PENDING)
  emailVerifiedAt          DateTime?
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  createdAt                DateTime         @default(now())

  subscription  Subscription?
  categories    Category[]
  announcements Announcement[]
  scans         MenuScan[]

  @@map("restaurants")
}

model Subscription {
  id           String           @id @default(cuid())
  restaurantId String           @unique
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type         SubscriptionType
  startsAt     DateTime
  endsAt       DateTime
  createdAt    DateTime         @default(now())

  @@map("subscriptions")
}

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  imageUrl     String?
  order        Int        @default(0)
  createdAt    DateTime   @default(now())

  products Product[]

  @@index([restaurantId])
  @@map("categories")
}

model Product {
  id              String   @id @default(cuid())
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  discountedPrice Decimal? @db.Decimal(10, 2)
  preparationTime Int?
  calories        Int?
  allergens       String?
  imageUrl        String?
  isAvailable     Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([categoryId])
  @@map("products")
}

model Announcement {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  title        String
  body         String
  imageUrl     String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@map("announcements")
}

model MenuScan {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  scannedAt    DateTime   @default(now())

  @@index([restaurantId, scannedAt])
  @@map("menu_scans")
}

model Admin {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  logs         AdminLog[]

  @@map("admins")
}

enum AdminAction {
  APPROVE_TRIAL
  APPROVE_ANNUAL
  RENEW_TRIAL
  RENEW_ANNUAL
  SUSPEND
}

model AdminLog {
  id             String      @id @default(cuid())
  adminId        String
  admin          Admin       @relation(fields: [adminId], references: [id])
  restaurantId   String
  restaurantName String
  restaurantSlug String
  action         AdminAction
  createdAt      DateTime    @default(now())

  @@index([createdAt])
  @@map("admin_logs")
}
